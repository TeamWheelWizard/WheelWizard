<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:WheelWizard.Views.Components"
             xmlns:input="clr-namespace:WheelWizard.Services.Input"
             xmlns:pages="clr-namespace:WheelWizard.Views.Pages"
             mc:Ignorable="d" d:DesignWidth="656" d:DesignHeight="876"
             x:Class="WheelWizard.Views.Pages.InputPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource TopRowSize}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource BackgroundLineColor}" Height="1"
                HorizontalAlignment="Stretch" VerticalAlignment="Bottom" />
        <Border Grid.Row="1" Background="{StaticResource BackgroundLineColor}" Height="1"
                HorizontalAlignment="Stretch" VerticalAlignment="Bottom" />

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
            <TextBlock Text="Input" Classes="PageTitleText" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="10,12">
                <components:Button x:Name="ReloadButton"
                                   Text="Reload"
                                   Variant="Default"
                                   Click="ReloadButton_OnClick" />
                <components:Button x:Name="AutoMapButton"
                                   Text="Auto Map"
                                   Variant="Primary"
                                   Click="AutoMapButton_OnClick" />
                <CheckBox x:Name="RumbleToggle"
                          Classes="SwitchDark"
                          Content="Rumble"
                          Click="RumbleToggle_OnClick" />
            </StackPanel>
        </Grid>

        <components:EmptyPageInfo Grid.Row="1"
                                  x:Name="NoControllerInfo"
                                  IsVisible="False"
                                  Title="No controller connected"
                                  BodyText="Keyboard controls still work even when no controller is connected." />

        <ScrollViewer Grid.Row="1"
                      x:Name="InputContent"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,10,10,16" Spacing="10">
                <Grid ColumnDefinitions="*,*">
                    <StackPanel Spacing="6" Margin="0,0,8,0">
                        <TextBlock Text="Input Device"
                                   Classes="TitleText"
                                   FontSize="18"
                                   Foreground="{StaticResource Neutral100}" />
                        <ComboBox x:Name="ControllerDropdown"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ControllerDropdown_OnSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="input:ControllerDeviceOption">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding DisplayName}" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Classes="TinyText"
                                                   Foreground="{StaticResource Neutral400}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6" Margin="8,0,0,0">
                        <TextBlock Text="Preset"
                                   Classes="TitleText"
                                   FontSize="18"
                                   Foreground="{StaticResource Neutral100}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <ComboBox x:Name="PresetDropdown"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="PresetDropdown_OnSelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="input:MarioKartInputPresetOption">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       Classes="TinyText"
                                                       Foreground="{StaticResource Neutral400}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <StackPanel Grid.Column="1" Spacing="3" Margin="6,0,0,0">
                                <components:Button x:Name="AddPresetButton"
                                                   Text="+"
                                                   Width="28"
                                                   Height="20"
                                                   Padding="0"
                                                   FontSize="13"
                                                   ToolTip.Tip="Add preset"
                                                   Click="AddPresetButton_OnClick" />
                                <components:Button x:Name="DeletePresetButton"
                                                   Text="-"
                                                   Width="28"
                                                   Height="20"
                                                   Padding="0"
                                                   FontSize="13"
                                                   ToolTip.Tip="Delete preset"
                                                   Click="DeletePresetButton_OnClick" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Border Background="{StaticResource Neutral900}"
                        BorderBrush="{StaticResource Neutral700}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource GlobalCornerRadius}"
                        Padding="0">
                    <ItemsControl x:Name="BindingsList">
                        <ItemsControl.Styles>
                            <Style Selector="TextBlock.bindingTitle">
                                <Setter Property="Foreground" Value="{StaticResource Neutral100}" />
                            </Style>
                            <Style Selector="TextBlock.bindingTitle.pressed">
                                <Setter Property="Foreground" Value="{StaticResource Primary300}" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="pages:InputBindingRow">
                                <Border BorderBrush="{StaticResource Neutral700}"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,12">
                                    <Grid ColumnDefinitions="170,*,Auto"
                                          VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Classes.pressed="{Binding IsPressed}"
                                                   Classes="TitleText bindingTitle"
                                                   FontSize="17"
                                                   Margin="0,0,14,0"
                                                   VerticalAlignment="Center" />

                                        <components:Button Grid.Column="1"
                                                           Text="{Binding ActionButtonText}"
                                                           Tag="{Binding Action}"
                                                           Width="156"
                                                           Margin="0,0,10,0"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           PointerPressed="BindingButton_OnPointerPressed"
                                                           Click="ChangeBinding_OnClick" />

                                        <components:Button Grid.Column="2"
                                                           Text=">"
                                                           Width="42"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding IsAdvancedVisible}"
                                                           Tag="{Binding Action}"
                                                           Click="AdvancedBinding_OnClick" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
