<base:PopupContent x:Class="WheelWizard.Views.Popups.Input.DirectionalBindingWindow"
                   xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:components="clr-namespace:WheelWizard.Views.Components"
                   xmlns:base="clr-namespace:WheelWizard.Views.Popups.Base"
                   ClipToBounds="False"
                   mc:Ignorable="d"
                   d:DesignWidth="760"
                   d:DesignHeight="620">
    <Grid Width="760"
          RowDefinitions="Auto,Auto,*,Auto">
        <StackPanel Spacing="4"
                    Margin="0,0,0,14">
            <TextBlock x:Name="TitleText"
                       Classes="TitleText"
                       FontSize="20"
                       Foreground="{StaticResource Neutral50}" />
            <TextBlock x:Name="SummaryText"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource Neutral300}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Background="{StaticResource Neutral900}"
                BorderBrush="{StaticResource Neutral700}"
                BorderThickness="1"
                CornerRadius="{StaticResource GlobalCornerRadius}"
                Padding="12">
            <TextBlock x:Name="StatusText"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource Neutral200}" />
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,14"
                Background="{StaticResource Neutral900}"
                BorderBrush="{StaticResource Neutral700}"
                BorderThickness="1"
                CornerRadius="{StaticResource GlobalCornerRadius}"
                Padding="0">
            <StackPanel Spacing="0">
                <Grid ColumnDefinitions="76,64,*,Auto,Auto"
                      RowDefinitions="Auto,Auto"
                      Margin="14,12">
                    <TextBlock Grid.RowSpan="2"
                               Text="Up"
                               Classes="TitleText"
                               FontSize="17"
                               Foreground="{StaticResource Neutral100}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="Main"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               x:Name="UpMainValueText"
                               Margin="12,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <components:Button Grid.Column="3"
                                       x:Name="UpMainButton"
                                       Tag="up:0"
                                       Text="Change"
                                       Width="124"
                                       Margin="10,0,0,0"
                                       Click="ChangeDirection_OnClick" />
                    <components:Button Grid.Column="4"
                                       x:Name="UpMainClearButton"
                                       Tag="up:0"
                                       Text="Clear"
                                       Width="92"
                                       Margin="10,0,0,0"
                                       Variant="Default"
                                       Click="ClearDirection_OnClick" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,10,0,0"
                               Text="Extra"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               x:Name="UpExtraValueText"
                               Margin="12,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <components:Button Grid.Row="1"
                                       Grid.Column="3"
                                       x:Name="UpExtraButton"
                                       Tag="up:1"
                                       Text="Change"
                                       Width="124"
                                       Margin="10,10,0,0"
                                       Click="ChangeDirection_OnClick" />
                    <components:Button Grid.Row="1"
                                       Grid.Column="4"
                                       x:Name="UpExtraClearButton"
                                       Tag="up:1"
                                       Text="Clear"
                                       Width="92"
                                       Margin="10,10,0,0"
                                       Variant="Default"
                                       Click="ClearDirection_OnClick" />
                </Grid>

                <Border Background="{StaticResource Neutral700}" Height="1" />

                <Grid ColumnDefinitions="76,64,*,Auto,Auto"
                      RowDefinitions="Auto,Auto"
                      Margin="14,12">
                    <TextBlock Grid.RowSpan="2"
                               Text="Down"
                               Classes="TitleText"
                               FontSize="17"
                               Foreground="{StaticResource Neutral100}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="Main"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               x:Name="DownMainValueText"
                               Margin="12,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <components:Button Grid.Column="3"
                                       x:Name="DownMainButton"
                                       Tag="down:0"
                                       Text="Change"
                                       Width="124"
                                       Margin="10,0,0,0"
                                       Click="ChangeDirection_OnClick" />
                    <components:Button Grid.Column="4"
                                       x:Name="DownMainClearButton"
                                       Tag="down:0"
                                       Text="Clear"
                                       Width="92"
                                       Margin="10,0,0,0"
                                       Variant="Default"
                                       Click="ClearDirection_OnClick" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,10,0,0"
                               Text="Extra"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               x:Name="DownExtraValueText"
                               Margin="12,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <components:Button Grid.Row="1"
                                       Grid.Column="3"
                                       x:Name="DownExtraButton"
                                       Tag="down:1"
                                       Text="Change"
                                       Width="124"
                                       Margin="10,10,0,0"
                                       Click="ChangeDirection_OnClick" />
                    <components:Button Grid.Row="1"
                                       Grid.Column="4"
                                       x:Name="DownExtraClearButton"
                                       Tag="down:1"
                                       Text="Clear"
                                       Width="92"
                                       Margin="10,10,0,0"
                                       Variant="Default"
                                       Click="ClearDirection_OnClick" />
                </Grid>

                <Border Background="{StaticResource Neutral700}" Height="1" />

                <Grid ColumnDefinitions="76,64,*,Auto,Auto"
                      RowDefinitions="Auto,Auto"
                      Margin="14,12">
                    <TextBlock Grid.RowSpan="2"
                               Text="Left"
                               Classes="TitleText"
                               FontSize="17"
                               Foreground="{StaticResource Neutral100}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="Main"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               x:Name="LeftMainValueText"
                               Margin="12,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <components:Button Grid.Column="3"
                                       x:Name="LeftMainButton"
                                       Tag="left:0"
                                       Text="Change"
                                       Width="124"
                                       Margin="10,0,0,0"
                                       Click="ChangeDirection_OnClick" />
                    <components:Button Grid.Column="4"
                                       x:Name="LeftMainClearButton"
                                       Tag="left:0"
                                       Text="Clear"
                                       Width="92"
                                       Margin="10,0,0,0"
                                       Variant="Default"
                                       Click="ClearDirection_OnClick" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,10,0,0"
                               Text="Extra"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               x:Name="LeftExtraValueText"
                               Margin="12,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <components:Button Grid.Row="1"
                                       Grid.Column="3"
                                       x:Name="LeftExtraButton"
                                       Tag="left:1"
                                       Text="Change"
                                       Width="124"
                                       Margin="10,10,0,0"
                                       Click="ChangeDirection_OnClick" />
                    <components:Button Grid.Row="1"
                                       Grid.Column="4"
                                       x:Name="LeftExtraClearButton"
                                       Tag="left:1"
                                       Text="Clear"
                                       Width="92"
                                       Margin="10,10,0,0"
                                       Variant="Default"
                                       Click="ClearDirection_OnClick" />
                </Grid>

                <Border Background="{StaticResource Neutral700}" Height="1" />

                <Grid ColumnDefinitions="76,64,*,Auto,Auto"
                      RowDefinitions="Auto,Auto"
                      Margin="14,12">
                    <TextBlock Grid.RowSpan="2"
                               Text="Right"
                               Classes="TitleText"
                               FontSize="17"
                               Foreground="{StaticResource Neutral100}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="Main"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               x:Name="RightMainValueText"
                               Margin="12,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <components:Button Grid.Column="3"
                                       x:Name="RightMainButton"
                                       Tag="right:0"
                                       Text="Change"
                                       Width="124"
                                       Margin="10,0,0,0"
                                       Click="ChangeDirection_OnClick" />
                    <components:Button Grid.Column="4"
                                       x:Name="RightMainClearButton"
                                       Tag="right:0"
                                       Text="Clear"
                                       Width="92"
                                       Margin="10,0,0,0"
                                       Variant="Default"
                                       Click="ClearDirection_OnClick" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,10,0,0"
                               Text="Extra"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               x:Name="RightExtraValueText"
                               Margin="12,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Neutral300}"
                               VerticalAlignment="Center" />
                    <components:Button Grid.Row="1"
                                       Grid.Column="3"
                                       x:Name="RightExtraButton"
                                       Tag="right:1"
                                       Text="Change"
                                       Width="124"
                                       Margin="10,10,0,0"
                                       Click="ChangeDirection_OnClick" />
                    <components:Button Grid.Row="1"
                                       Grid.Column="4"
                                       x:Name="RightExtraClearButton"
                                       Tag="right:1"
                                       Text="Clear"
                                       Width="92"
                                       Margin="10,10,0,0"
                                       Variant="Default"
                                       Click="ClearDirection_OnClick" />
                </Grid>
            </StackPanel>
        </Border>

        <components:Button Grid.Row="3"
                           Text="Done"
                           Width="140"
                           HorizontalAlignment="Center"
                           Variant="Primary"
                           Click="DoneButton_OnClick" />
    </Grid>
</base:PopupContent>
