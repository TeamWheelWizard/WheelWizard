<local:BaseWindow xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:local="clr-namespace:WheelWizard.Views"
                  xmlns:components="clr-namespace:WheelWizard.Views.Components"
                  mc:Ignorable="d"
                  x:Class="WheelWizard.Views.MiiRenderingSetupWindow"
                  Width="560"
                  Height="360"
                  MinWidth="560"
                  MinHeight="360"
                  MaxWidth="560"
                  MaxHeight="360"
                  CanResize="False"
                  WindowStartupLocation="CenterScreen"
                  SystemDecorations="Full">
    <Grid>
        <Grid x:Name="MainContent" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Margin="28">
            <TextBlock x:Name="TitleTextBlock"
                       Classes="TitleText"
                       Text="Mii Rendering Setup" />

            <TextBlock Grid.Row="1"
                       Margin="0,14,0,0"
                       TextWrapping="Wrap"
                       Classes="BodyText"
                       Text="Wheel Wizard needs one external file to render Miis offline. Download it once and it will be stored in your Wheel Wizard data folder." />

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="#12000000"
                    BorderBrush="{StaticResource Neutral700}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel Spacing="8">
                    <TextBlock Classes="BodyText"
                               FontWeight="SemiBold"
                               Text="Install location" />
                    <TextBlock x:Name="PathTextBlock"
                               Classes="BodyText"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Margin="0,18,0,0" Spacing="8">
                <TextBlock x:Name="StatusTextBlock"
                           Classes="BodyText"
                           TextWrapping="Wrap" />
                <ProgressBar x:Name="DownloadProgressBar"
                             Minimum="0"
                             Maximum="100"
                             Height="10" />
                <TextBlock x:Name="ProgressTextBlock"
                           Classes="BodyText"
                           Opacity="0.75" />
                <TextBlock x:Name="ErrorTextBlock"
                           Classes="BodyText"
                           Foreground="{StaticResource Danger400}"
                           TextWrapping="Wrap"
                           IsVisible="False" />
            </StackPanel>

            <Border Grid.Row="4"
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="#12000000"
                    BorderBrush="{StaticResource Neutral700}"
                    BorderThickness="1"
                    CornerRadius="10">
                <TextBlock Classes="BodyText"
                           TextWrapping="Wrap"
                           Text="Closing this window exits Wheel Wizard. The main app will only open after the required Mii rendering file is installed." />
            </Border>

            <UniformGrid Grid.Row="5"
                         Columns="2"
                         Margin="0,24,0,0">
                <components:Button x:Name="CloseButton"
                                   Margin="0,0,6,0"
                                   Variant="Default"
                                   Text="Close"
                                   Click="CloseButton_OnClick" />
                <components:Button x:Name="DownloadButton"
                                   Margin="6,0,0,0"
                                   Variant="Primary"
                                   Text="Download"
                                   Click="DownloadButton_OnClick" />
            </UniformGrid>
        </Grid>

        <Border x:Name="DisabledOverlay"
                IsVisible="False"
                Background="#66000000" />
    </Grid>
</local:BaseWindow>
